# OpenAI is used for both embeddings and chat completions.
# Any account/key you already have works - text-embedding-3-small and gpt-4o-mini
# are cheap enough that a small crawl costs pennies.
OPENAI_API_KEY=sk-...

# Port the backend listens on
PORT=8080

# Crawl limits - kept small on purpose so a demo run finishes in under a minute.
# Override per-request from the frontend too, these are just the defaults.
MAX_PAGES=25
MAX_DEPTH=3
CRAWL_DELAY_MS=400
